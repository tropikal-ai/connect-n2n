{
    "name": "tropikal-ai/connect-n2n",
    "description": "TROPIKAL Connect integration for n2n. Plain-ORM by default; optional Rocket CMF discovery.",
    "keywords": [
        "tropikal",
        "connect",
        "n2n",
        "orm",
        "rocket"
    ],
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Tropikal AI"
        }
    ],
    "require": {
        "php": ">=8.4",
        "ext-curl": "*",
        "ext-json": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*",
        "n2n/n2n-bind": "~7.5.0@dev",
        "n2n/n2n-persistence": "~7.5.0@dev",
        "n2n/n2n-web": "~7.5.0@dev",
        "tropikal-ai/connect": "^0.1"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "n2n/n2n": "~7.5.0@dev",
        "n2n/n2n-test": "^7.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^11.0|^12.0"
    },
    "autoload": {
        "psr-4": {
            "tropikal\\connect\\n2n\\": "src/app/tropikal/connect/n2n"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "tropikal\\connect\\n2n\\tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-main": "0.1-dev"
        }
    },
    "scripts": {
        "analyse": "phpstan analyse",
        "format": "pint",
        "test": "phpunit --colors=never"
    },
    "config": {
        "allow-plugins": {
            "n2n/n2n-composer-module-installer": true
        },
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
