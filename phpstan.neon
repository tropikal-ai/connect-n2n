parameters:
    level: 5
    paths:
        - src
    tmpDir: build/phpstan
    parallel:
        maximumNumberOfProcesses: 1
    ignoreErrors:
        # n2n invokes the private magic _init() and _annotations() by
        # reflection; PHPStan can't see the calls.
        -
            identifier: method.unused
            message: '#Method .*ConnectControllerBase::_init\(\) is unused#'
            path: src/app/tropikal/connect/n2n/web/ConnectControllerBase.php
        -
            identifier: method.unused
            message: '#Static method .*::_annos\(\) is unused#'
            path: src/app/tropikal/connect/n2n/web
